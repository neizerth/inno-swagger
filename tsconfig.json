{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"lib": ["ES2020"],
		"strict": true,
		"baseUrl": "./",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"paths": {
			"@src/*": ["src/*"]
		},
		"useUnknownInCatchVariables": false,
		"types": ["vitest/globals"]
	},
	"ts-node": {
		"require": ["tsconfig-paths/register", "dotenv/config"]
	},
	"include": [
		"src/**/*.ts",
		"tests/**/*.ts",
		"scripts",
		"eslint.config.ts",
		"vitest.config.mts",
		"users.test1.ts"
	],
	"exclude": ["src/public/*"]
}
